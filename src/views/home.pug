html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title RandomRoom
        link(rel="stylesheet" href="https://unpkg.com/mvp.css")
        style.
            @keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @keyframes fadeOut {
                from {
                    opacity: 1;
                    transform: translateY(0);
                }
                to {
                    opacity: 0;
                    transform: translateY(-20px);
                }
            }

            body {
                background-color: #121212;
                color: #f1f1f1;
                font-family: 'Roboto', sans-serif;
                margin: 0;
                padding: 0;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                transition: background-color 0.3s ease;
            }

            header {
                padding: 20px;
                text-align: center;
                animation: fadeIn 1s ease-in-out;
            }

            header h1 {
                font-size: 3rem;
                margin: 0;
                color: #4CAF50;
            }

            header h3 {
                font-size: 1.2rem;
                margin-top: 10px;
                color: #a1a1a1;
            }

            #choose, #welcome {
                width: 100%;
                max-width: 600px;
                padding: 20px;
                border-radius: 10px;
                animation: fadeIn 1s ease-in-out;
                background-color: #1e1e1e;
            }

            button {
                font-size: 1rem;
                padding: 10px 20px;
                margin: 5px 0;
                border: none;
                border-radius: 5px;
                cursor: pointer;
                transition: background-color 0.3s ease;
            }

            button:hover {
                background-color: #3e8e41;
            }

            input[type="text"] {
                padding: 10px;
                width: 100%;
                border: 1px solid #444;
                border-radius: 5px;
                margin-bottom: 10px;
                background-color: #2a2a2a;
                color: #f1f1f1;
                font-size: 1rem;
            }

            .message-container {
                flex: 1; /* 남은 공간을 메시지 컨테이너가 차지 */
                list-style: none;
                padding: 10px;
                margin: 0;
                display: flex;
                flex-direction: column;
                overflow-y: auto;
                border: 1px solid #444;
                background-color: #222;
                border-radius: 10px;
                width : 800px;
                box-sizing : border-box;
            }

            .message {
                margin-bottom: 10px;
                padding: 10px;
                max-width: 70%;
                border-radius: 10px;
                position: relative;
                color: #fff;
                font-size: 16px;
                word-wrap: break-word;
            }

            .message.you {
                background-color: #4CAF50;
                align-self: flex-end;
            }

            .message.other {
                background-color: #555;
                align-self: flex-start;
            }

            .message::after {
                content: '';
                position: absolute;
                width: 0;
                height: 0;
                border: 10px solid transparent;
            }

            .message.you::after {
                border-right-color: #4CAF50;
                border-left: 0;
                border-right: 10px solid #4CAF50;
                left: 100%;
                top: 10px;
            }

            .message.other::after {
                border-left-color: #555;
                border-right: 0;
                border-left: 10px solid #555;
                right: 100%;
                top: 10px;
            }

            form#msg {
                display: flex;
                justify-content: space-between;
                margin-top: 10px;
                width : 100%;
                box-sizing : border-box;
            }

            form#msg input {
                flex: 1;
                padding: 10px;
                margin-right: 10px;
                border-radius: 5px;
                box-sizing: border-box;
            }

            form#msg button {
                padding: 10px;
                border-radius: 5px;
                background-color: #4CAF50;
                color: white;
                border: none;
                box-sizing: border-box;
            }

            main {
                display: flex;
                flex-direction: column;
                padding: 0;
            }

            #room {
                width: 800px;
                height: 80vh; /* 전체 페이지 높이의 80%를 차지 */
                margin-top: 0;
                order: 1;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                box-sizing : border-box;
            }

            #room h3 {
                margin: 0 0 10px 0;
                font-size: 1.5rem;
                text-align: center;
                width : 100%;
            }

            #welcome {
                flex-direction: column; /* 자식 요소들을 수직으로 배치 */
                justify-content: center; /* 수직 중앙 정렬 */
                align-items: center; /* 수평 중앙 정렬 */
                display: flex;
            }

            #nickname input {
                width: 600px; /* 원하는 가로 길이로 설정 */
                padding: 10px; /* 입력 필드의 내부 여백 추가 */
                box-sizing: border-box; /* 패딩을 포함한 너비 조정 */
                color : black;
            }

            #roomname button {
                width: 100%;
                padding: 10px;
            }

            #GroupSelect {
                position: relative;
                width: 50%; /* form의 너비를 설정하여 중앙에 배치 */
                margin: 0 auto; /* form을 페이지 중앙에 위치 */
                text-align: center; /* 버튼들을 수평으로 중앙에 정렬 */
            }

            #GroupSelect button {
                margin-bottom: 20px; /* 버튼 사이에 20px의 여백 추가 */
            }
            #Group, #oneOnone {
                flex: 1;
                margin: 20px; /* 버튼 사이에 여백 추가 */
            }
            #room[hidden] {
                display: none;
            }
    body(style="background-color: black; color: white;")
        header 
            h1 RandomRoom
                h3#SubTitle
        main
            div#choose
                form#GroupSelect
                    button#Group 랜덤 그룹챗
                    button#oneOnone 랜덤 1대1 채팅
            div#welcome
                form#nickname
                    input(placeholder="닉네임을 입력하세요", required, type="text" style="background-color: white;")
                    button 저장
                form#roomname
                    button 방 입장
            div#room
                h3
                ul.message-container
                form#msg
                    input(placeholder="message", required, type="text")
                    button Send
        script(src="/socket.io/socket.io.js")
        script(src="/public/js/app.js")