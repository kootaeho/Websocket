html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title RandomRoom
        link(rel="stylesheet" href="https://unpkg.com/mvp.css")
        style.
            .message-container {
                list-style: none;
                padding: 0;
                margin: 0;
                display: flex;
                flex-direction: column;
                overflow-y: auto;
                height: 600px; /* 채팅 박스 높이 설정 */
                border: 1px solid #444;
                padding: 10px;
                background-color: #222;
                border-radius: 10px;
            }
            .message {
                margin-bottom: 10px;
                padding: 10px;
                max-width: 70%;
                border-radius: 10px;
                position: relative;
                color: #fff;
                font-size: 16px;
                word-wrap: break-word;
            }
            .message.you {
                background-color: #4CAF50;
                align-self: flex-end;
            }
            .message.other {
                background-color: #555;
                align-self: flex-start;
            }
            .message::after {
                content: '';
                position: absolute;
                width: 0;
                height: 0;
                border: 10px solid transparent;
            }
            .message.you::after {
                border-right-color: #4CAF50;
                border-left: 0;
                border-right: 10px solid #4CAF50;
                left: 100%;
                top: 10px;
            }
            .message.other::after {
                border-left-color: #555;
                border-right: 0;
                border-left: 10px solid #555;
                right: 100%;
                top: 10px;
            }
            form#msg {
                display: flex;
                justify-content: space-between;
                margin-top: 20px;
            }
            form#msg input {
                flex: 1;
                padding: 10px;
                margin-right: 10px;
                border-radius: 5px;
            }
            form#msg button {
                padding: 10px;
                border-radius: 5px;
                background-color: #4CAF50;
                color: white;
                border: none;
            }
            main {
                display: flex;
                flex-direction: column;
                padding: 0;
            }
            #room {
                margin-top: 0; /* 위쪽 마진만 제거 */
                
                order : 1;
            }
            header {
                padding : 10px;
                height : auto;
            }
            header h1 {
                font-size : 35px;
                margin : 0;
            }
            #welcome {
                flex-direction: column; /* 자식 요소들을 수직으로 배치 */
                justify-content: center; /* 수직 중앙 정렬 */
                align-items: center; /* 수평 중앙 정렬 */
                display: flex;
            }
            #nickname input {
                width: 600px; /* 원하는 가로 길이로 설정 */
                padding: 10px; /* 입력 필드의 내부 여백 추가 */
                box-sizing: border-box; /* 패딩을 포함한 너비 조정 */
            }
            #roomname button {
                width: 100%;
                padding: 10px;
            }
            #GroupSelect {
                position: relative;
                width: 50%; /* form의 너비를 설정하여 중앙에 배치 */
                margin: 0 auto; /* form을 페이지 중앙에 위치 */
                text-align: center; /* 버튼들을 수평으로 중앙에 정렬 */
            }
            #Group, #oneOnone {
                flex: 1;
                margin: 0 20px; /* 버튼 사이에 여백 추가 */
            }
    body(style="background-color: black; color: white;")
        header 
            h1 RandomRoom
                h3#SubTitle
        main
            div#choose
                form#GroupSelect
                    button#Group 랜덤 그룹챗
                    button#oneOnone 랜덤 1대1 채팅
            div#welcome
                form#nickname
                    input(placeholder="닉네임을 입력하세요", required, type="text" style="background-color: white;")
                    button 저장
                form#roomname
                    // input(placeholder="room name", required, type="text")
                    button 방 입장
            div#room
                h3
                ul.message-container
                form#msg
                    input(placeholder="message", required, type="text")
                    button Send
        script(src="/socket.io/socket.io.js")
        script(src="/public/js/app.js")
